CELERY_TASK_ALWAYS_EAGER=false
OPENAI_API_KEY=
DEFAULT_QUERY_LIMIT=100
QUERY_TIMEOUT_SECONDS=15
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1
