flowchart TD
  user[Business User] --> web[Next.js Frontend]
  web --> api[FastAPI API Gateway]
  api --> auth[JWT Auth + RBAC]
  auth --> supervisor[LangGraph Supervisor]
  supervisor --> planner[Workflow Planner]
  planner --> router[Model Router]
  router --> agents[Enterprise Agent Layer]
  agents --> semantic[Semantic Layer]
  agents --> rag[RAG Knowledge Search]
  agents --> safety[Query Safety + Governance]
  safety --> analytics[Analytics Execution]
  analytics --> pg[(PostgreSQL)]
  analytics --> mongo[(MongoDB)]
  analytics --> redis[(Redis + Celery)]
  api --> realtime[WebSocket + SSE Realtime]
  api --> observability[Prometheus Metrics + Agent Traces]
  api --> reports[Dashboards + Reports + Exports]
  agents --> external[External APIs + Databases + SaaS]
