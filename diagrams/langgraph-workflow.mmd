flowchart LR
  intent[Intent Classification] --> planner[Workflow Planner]
  planner --> router[Model Router]
  router --> schema[Schema Intelligence]
  schema --> semantic[Semantic Layer]
  semantic --> context[Business Context]
  context --> rag[RAG Knowledge Agent]
  rag --> quality[Data Quality]
  quality --> lineage[Data Lineage]
  lineage --> branch{Intent}
  branch -->|Analytics| clarify[Clarification]
  branch -->|Import| etl[ETL Agent]
  branch -->|API Sync| api[Enterprise API Agent]
  api --> clarify
  clarify --> query[SQL / MongoDB Query Agent]
  query --> validate[Query Validation]
  validate --> optimize[Query Optimization]
  optimize --> execute[Query Execution]
  execute --> insights[Insight Generation]
  insights --> executive[Executive Decision]
  executive --> anomaly[Anomaly Detection]
  anomaly --> forecast[Forecasting]
  forecast --> viz[Visualization]
  viz --> dashboard[Dashboard Builder]
  dashboard --> report[Report Writer]
  report --> memory[Memory]
  memory --> recs[Recommendations]
  recs --> approval[Collaboration + Human Approval]
  approval --> governance[Policy / Governance]
  governance --> security[Security & Compliance]
  security --> cost[Cost Governance]
  cost --> monitoring[Monitoring + Observability]
  monitoring --> explanation[Final Explanation]
